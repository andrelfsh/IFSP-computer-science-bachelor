<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BAT-COMPUTER // COGNITIVE THREAT ANALYSIS"
        android:textColor="#00FF00"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:fontFamily="monospace" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Codinome do Alvo:"
        android:textColor="#888888"
        android:textSize="12sp"
        android:fontFamily="monospace" />

    <EditText
        android:id="@+id/edNomeAlvo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ex: joker, batman, riddler"
        android:textColor="#FFFFFF"
        android:textColorHint="#444444"
        android:inputType="text"
        android:backgroundTint="#00FF00"
        android:fontFamily="monospace" />

    <Button
        android:id="@+id/btnPesquisar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Escanear Assinatura"
        android:onClick="pesquisar"
        android:backgroundTint="#222222"
        android:textColor="#00FF00"
        android:layout_marginTop="8dp"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/txtConsole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="[SISTEMA EM ESPERA // AGUARDANDO INPUT DIRETRIZ]"
        android:textColor="#00FF00"
        android:textSize="14sp"
        android:fontFamily="monospace" />

</LinearLayout>